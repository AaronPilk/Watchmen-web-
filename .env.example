# Resend — contact + application form email delivery
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Verified sending domain address (sending domain TBD — default noreply@gy6.me)
RESEND_FROM_EMAIL="The Watchmen <noreply@gy6.me>"

# Inbound address that receives form submissions
RESEND_TO_EMAIL=hello@thewatchmen.com

# Applications are CC'd to the advisory team
RESEND_APPLY_CC_EMAIL=dustin@gy6.me

# Optional: public site URL used for metadata / sitemap / OG (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://gy6.me
